generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  summary   String?
  url       String   @unique
  source    String
  published DateTime?
  content   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}